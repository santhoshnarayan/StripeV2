# ===========================================
# StripeV2 Environment Variables
# ===========================================
# Copy this to .env and fill in values.
# Run `stripe projects env --pull` to auto-populate provider credentials.

# --- Database (PlanetScale) ---
# Auto-populated by: stripe projects env --pull
DATABASE_URL="postgresql://user:password@host:5432/db?sslmode=verify-full&sslrootcert=system"

# --- Auth (Better Auth) ---
# Generate with: openssl rand -base64 32
BETTER_AUTH_SECRET=""
# URL where the backend server runs
BETTER_AUTH_URL="http://localhost:4000"

# --- Server ---
PORT=4000
FRONTEND_URL="http://localhost:3000"

# --- Redis (Railway) ---
# Injected automatically by Railway at deploy time.
# For local dev, run Redis locally or leave blank (server starts without it).
REDIS_URL=""

# --- Frontend ---
NEXT_PUBLIC_API_URL="http://localhost:4000"

# --- Stripe Projects (auto-populated) ---
# PLANETSCALE_URL=
# PLANETSCALE_HOST=
# PLANETSCALE_DATABASE=
# PLANETSCALE_USERNAME=
# PLANETSCALE_PASSWORD=
# RAILWAY_HOSTING_URL=
# RAILWAY_HOSTING_DOMAIN=
# VERCEL_TOKEN=
# VERCEL_PROJECT_ID=
