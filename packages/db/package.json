{
  "name": "@repo/db",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "exports": {
    ".": "./src/index.ts",
    "./schema": "./src/schema/index.ts"
  },
  "scripts": {
    "build": "tsc",
    "db:generate": "dotenv -e ../../.env -- drizzle-kit generate",
    "db:migrate": "dotenv -e ../../.env -- drizzle-kit migrate",
    "db:push": "dotenv -e ../../.env -- drizzle-kit push"
  },
  "dependencies": {
    "@neondatabase/serverless": "0.10.4",
    "drizzle-orm": "0.41.0",
    "postgres": "3.4.9"
  },
  "devDependencies": {
    "@repo/tsconfig": "workspace:*",
    "@types/node": "22.19.17",
    "dotenv-cli": "8.0.0",
    "drizzle-kit": "0.30.6",
    "typescript": "5.9.3"
  }
}
