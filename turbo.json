{
  "$schema": "https://turbo.build/schema.json",
  "globalEnv": [
    "DATABASE_URL",
    "PLANETSCALE_URL",
    "BETTER_AUTH_SECRET",
    "BETTER_AUTH_URL",
    "REDIS_URL",
    "FRONTEND_URL",
    "API_URL",
    "INTERNAL_API_TOKEN",
    "NEXT_PUBLIC_API_URL",
    "NODE_ENV",
    "PORT",
    "WEB_PORT",
    "DOCS_PORT"
  ],
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": ["dist/**", ".next/**", "!.next/cache/**"]
    },
    "dev": {
      "cache": false,
      "persistent": true
    },
    "lint": {
      "dependsOn": ["^build"]
    },
    "db:generate": {
      "cache": false
    },
    "db:push": {
      "cache": false
    }
  }
}
