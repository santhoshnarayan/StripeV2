{
  "name": "stripev2",
  "private": true,
  "scripts": {
    "setup": "./scripts/setup.sh",
    "dev": "./scripts/dev.sh",
    "dev:fe": "./scripts/dev.sh --filter=@repo/web",
    "build": "turbo build",
    "lint": "turbo lint",
    "db:generate": "dotenv -e .env -- pnpm --filter @repo/db db:generate",
    "db:push": "dotenv -e .env -- pnpm --filter @repo/db db:push",
    "db:apply-app-schema": "dotenv -e .env -- pnpm --filter @repo/db exec node scripts/apply-app-schema.mjs",
    "seed:users": "dotenv -e .env -- pnpm --filter @repo/server exec tsx src/scripts/seed-users.ts",
    "deploy": "./scripts/deploy.sh"
  },
  "devDependencies": {
    "dotenv-cli": "8.0.0",
    "turbo": "2.9.5"
  },
  "packageManager": "pnpm@10.5.1"
}
